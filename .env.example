# Alpaca (paper trading) — optional, system runs in simulation mode without these
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic — optional, system uses rule-based strategies without this
ANTHROPIC_API_KEY=your_claude_key_here

# Notifications (optional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# System
LOG_LEVEL=INFO
DASHBOARD_PORT=8080
